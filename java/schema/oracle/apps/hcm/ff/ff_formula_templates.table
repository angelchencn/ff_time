                  <PRECISION>9</PRECISION>
                  <SCALE>0</SCALE>
                  <DEFAULT>1</DEFAULT>
                  <NOT_NULL/>
                  <CUSTOMER_AREA>
                     <ODB_PROPERTY_LIST>
                        <COMMENT>Used to implement optimistic locking. This number is incremented every time that the row is updated. The number is compared at the start and end of a transaction to detect whether another session has updated the row since it was queried.</COMMENT>
